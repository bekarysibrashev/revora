# Application
APP_NAME=Revora API
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
TIMEZONE=Asia/Almaty
APP_PORT=8080

# PostgreSQL
POSTGRES_DB=revora
POSTGRES_USER=revora
POSTGRES_PASSWORD=revora
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://revora:revora@postgres:5432/revora

# Redis / Celery
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
FLOWER_PORT=5555

# MinIO
MINIO_ROOT_USER=revora
MINIO_ROOT_PASSWORD=revora-local-secret
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=revora
MINIO_SECRET_KEY=revora-local-secret
MINIO_SECURE=false
MINIO_BUCKET=revora
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Auth — replace before any shared deployment
JWT_SECRET_KEY=local-only-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Browser clients; JSON or comma-separated list is accepted
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
NEXT_PUBLIC_API_URL=/api/v1
